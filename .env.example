# ============================================
# Kraken 环境配置
# ============================================

# ---- 服务端口 ----
PORT=3000
NODE_ENV=development

# ---- Ollama ----
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=embeddinggemma
OLLAMA_FALLBACK_MODEL=qwen2.5:1.5b-instruct-q4_K_M

# ---- DeepSeek 推理 API（留空则自动使用 Ollama 兜底）----
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ---- Qdrant 向量数据库 ----
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=kraken_knowledge

# ---- 文本处理 ----
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ---- SearXNG 搜索 ----
SEARXNG_URL=http://localhost:8080
SEARXNG_ENABLED=true

# ---- 爬虫域名黑名单（逗号分隔，搜索结果中这些域名的 URL 会被过滤）----
# BLOCKED_DOMAINS=wikipedia.org,google.com,medium.com

# ---- 日志 ----
LOG_LEVEL=info
# 日志文件路径（留空=仅控制台）
LOG_FILE_PATH=./data/logs/kraken.log
