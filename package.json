{
  "name": "kraken",
  "version": "1.0.0",
  "description": "智能知识处理服务 - 基于 LangGraph 的网页内容抓取、摘要与向量化入库",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/ tests/",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\""
  },
  "keywords": ["langgraph", "knowledge-graph", "llm", "rag", "qdrant"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.5",
    "@langchain/openai": "^1.5.2",
    "@langchain/qdrant": "^1.0.3",
    "@langgraph-js/crawler": "^2.0.0",
    "@qdrant/js-client-rest": "^1.18.0",
    "axios": "^1.18.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.2",
    "hono": "^4.12.27",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
